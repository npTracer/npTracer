{
    "version": 10,
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default Config",
            "hidden": true
        },
        {
            "name": "windows",
            "inherits": "default",
            "displayName": "Windows default configuration",
            "binaryDir": "build",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "toolset": {
                "value": "v143,version=14.42",
                "strategy": "set"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        }
    ],
    "workflowPresets": [
        {
            "name": "default",
            "steps": [
                {
                    "type": "configure",
                    "name": "default"
                },
                {
                    "type": "build",
                    "name": "default"
                }
            ]
        }
    ]
}